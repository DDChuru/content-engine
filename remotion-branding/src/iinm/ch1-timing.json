      0.5,
      3.983,
      "Reporting an incident starts here. First \u2014 what happened?"
    ],
    [
      4.533,
      6.762,
      "Tap the type. This one's an injury on duty."
    ],
    [
      7.312,
      15.346,
      "Fill in the detail \u2014 the part of the body, and the effect. And watch the right side: the e-wizer guide explains the rule as you go."
    ],
    [
      15.896,
      21.237,
      "Set how long they're booked off. Up to thirteen days, it stays a normal lost-time injury."
    ],
    [
      21.787,
      23.505,
      "But fourteen days or more \u2014"
    ],
    [
      24.055,
      30.975,
      "\u2014 and e-wizer marks it a Section 24: a report to the Department of Labour. The form knew the law for you."
    ],
    [
      31.525,
      35.054,
      "Then log the report \u2014 and it routes itself to the right people."
    ]
  ],
